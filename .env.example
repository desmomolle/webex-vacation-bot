# ============================================================
# Webex Vacation Bot — Konfiguration
# ============================================================
# 1. Kopiere diese Datei: cp .env.example .env
# 2. Fülle die PFLICHT-Felder aus
# 3. Optional: passe Templates, Intervall und Extras an
# ============================================================


# ── PFLICHT ──────────────────────────────────────────────────

# Deine Webex-E-Mail-Adresse (wird verwendet um eigene Nachrichten zu erkennen)
MY_WEBEX_EMAIL=name@cisco.com

# Rückkehrdatum (Bot deaktiviert sich automatisch danach)
VACATION_END_DATE=2026-06-15

# Bot aktiv? (true = läuft, false = überspringt alle Polls)
VACATION_ENABLED=true

# ── WEBEX AUTH ────────────────────────────────────────────────

# Option A — OAuth2 (empfohlen für Urlaub, Tokens laufen nicht ab)
# Aus developer.webex.com → My Webex Apps → deine Integration kopieren
WEBEX_CLIENT_ID=
WEBEX_CLIENT_SECRET=
# Einmalig: python get_webex_token.py ausführen → speichert tokens.json

# Option B — Personal Access Token (nur für Tests, läuft nach ~12h ab)
# Von developer.webex.com → "Copy personal access token"
WEBEX_PAT=


# ── NACHRICHTEN-TEMPLATES ─────────────────────────────────────
# {end_date} wird automatisch durch das Rückkehrdatum ersetzt

# Nachricht an interne Kontakte (@cisco.com oder deine Domain)
MSG_INTERNAL=⚡ Auto-Reply: Hey, ich bin bis {end_date} im Urlaub und lese keine Nachrichten. Ich melde mich wenn ich zurück bin!

# Nachricht an externe Kontakte
MSG_EXTERNAL=⚡ Automatic out-of-office reply: Thank you for your message. I am currently out of office and will return on {end_date}. I will get back to you upon my return.


# ── OPTIONALE EINSTELLUNGEN ───────────────────────────────────

# Poll-Intervall in Minuten (Standard: 15)
POLL_INTERVAL=15

# Port für die Status-Webseite (Standard: 8080)
WEB_PORT=8080

# Speicherort der SQLite-Datenbank (im Container → immer /data/vacation.db)
SQLITE_PATH=/data/vacation.db


# ── TESTMODUS ─────────────────────────────────────────────────
# Nur auf diese E-Mail-Adressen antworten (kommagetrennt)
# TEST_MODE=false
# TEST_CONTACTS=kollege@cisco.com,test@example.com


# ── E-MAIL-VERSAND BEI URLAUBSENDE (optional) ─────────────────

# Empfänger des Abschluss-Reports (meist man selbst)
# MAIL_TO=name@cisco.com

# Option A — Gmail OAuth2 (empfohlen, kein App-Passwort nötig)
# Einmalig: python get_gmail_token.py ausführen
# GMAIL_CLIENT_ID=
# GMAIL_CLIENT_SECRET=

# Option B — SMTP (z.B. Outlook, Cisco Mail, Gmail mit App-Passwort)
# SMTP_HOST=smtp.office365.com
# SMTP_PORT=587
# SMTP_USER=name@cisco.com
# SMTP_PASSWORD=dein-passwort


# ── KI-SUMMARY (optional) ─────────────────────────────────────
# Klassifiziert Nachrichten bei Urlaubsende in "dringend / kann warten"
# Einer oder keiner — beide werden erkannt, Gemini hat Vorrang
# Kosten: ~Cent-Bereich (einmalig bei Urlaubsende, <1000 Tokens)

# GEMINI_API_KEY=
# OPENAI_API_KEY=
