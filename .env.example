# ============================================================
# Webex Vacation Bot — Configuration
# ============================================================
# Quick start (Synology / QNAP / Docker Desktop):
#   1. Only fill in WEBEX_CLIENT_ID + WEBEX_CLIENT_SECRET here
#   2. docker compose up -d
#   3. Browser: http://localhost:8080/setup → complete setup in the wizard
#
# Alternative: fill in all fields manually, then docker compose up -d
# ============================================================


# ── REQUIRED ─────────────────────────────────────────────────

# Your Webex email address (used to identify your own messages)
MY_WEBEX_EMAIL=your.name@cisco.com

# ── WEBEX AUTH ────────────────────────────────────────────────

# Option A — OAuth2 (recommended for vacations, tokens don't expire)
# From developer.webex.com → My Webex Apps → copy your integration
# Complete setup at: http://localhost:8080/setup
WEBEX_CLIENT_ID=
WEBEX_CLIENT_SECRET=
# One-time: open the wizard at /setup OR run python get_webex_token.py

# Option B — Personal Access Token (for testing only, expires after ~12h)
# From developer.webex.com → "Copy personal access token"
WEBEX_PAT=


# ── MESSAGE TEMPLATES ────────────────────────────────────────
# {end_date} is automatically replaced with the return date

# Message to internal contacts (@cisco.com or your domain)
MSG_INTERNAL=⚡ Auto-reply: Hi, I'm on vacation until {end_date} and not reading messages. I'll get back to you when I'm back!

# Message to external contacts
MSG_EXTERNAL=⚡ Automatic out-of-office reply: Thank you for your message. I am currently out of office and will return on {end_date}. I will get back to you upon my return.


# ── SECURITY ─────────────────────────────────────────────────

# Password for the setup wizard at /setup
# If not set: auto-generated and shown once in the logs
# → docker logs webex-vacation-bot | grep "SETUP WIZARD PASSWORD"
# SETUP_PASSWORD=

# Encryption key for Webex tokens (auto-generated if not set)
# Stored in /data/.key — back up this directory regularly!
# Only needed if you want to supply the key manually (e.g. for migration)
# ENCRYPTION_KEY=


# ── OPTIONAL SETTINGS ────────────────────────────────────────

# Domain for internal colleagues (messages from @this-domain → internal template)
# Default: cisco.com — change this if you use a different company domain
# INTERNAL_DOMAIN=cisco.com

# Return date + activation (can also be set in the wizard at /setup)
# VACATION_END_DATE=2026-06-15
# VACATION_ENABLED=true

# Poll interval in minutes (default: 15)
POLL_INTERVAL=15

# Port for the status web page (default: 8080)
WEB_PORT=8080

# Storage location for the SQLite database (inside container → always /data/vacation.db)
SQLITE_PATH=/data/vacation.db


# ── TEST MODE ────────────────────────────────────────────────
# Only reply to these email addresses (comma-separated)
# TEST_MODE=false
# TEST_CONTACTS=colleague@cisco.com,test@example.com


# ── EMAIL NOTIFICATION AT VACATION END (optional) ─────────────

# Recipient of the end-of-vacation report (usually yourself)
# MAIL_TO=your.name@company.com

# Option A — Gmail OAuth2 (recommended, no app password needed)
# One-time: run python get_gmail_token.py
# GMAIL_CLIENT_ID=
# GMAIL_CLIENT_SECRET=

# Option B — SMTP (e.g. Outlook, Cisco Mail, Gmail with app password)
# SMTP_HOST=smtp.office365.com
# SMTP_PORT=587
# SMTP_USER=your.name@company.com
# SMTP_PASSWORD=your-password


# ── AI SUMMARY (optional) ─────────────────────────────────────
# Classifies messages at vacation end into "urgent / can wait"
# Use one or neither — both are supported, Gemini takes priority
# Cost: ~cents (one-time at vacation end, <1000 tokens)

# GEMINI_API_KEY=
# OPENAI_API_KEY=

# ─────────────────────────────────────────────────────────────
# Demo mode — click through the whole app without real Webex credentials
# ─────────────────────────────────────────────────────────────
# DEMO_MODE=true   → seeds sample data, stubs the OAuth step in the wizard,
#                    and simulates an incoming message every few seconds.
#                    NO real Webex/mail/LLM calls are made.
#                    Login password defaults to "demo".
# DEMO_MODE=false
# DEMO_POLL_SECONDS=30   # interval for simulated messages
